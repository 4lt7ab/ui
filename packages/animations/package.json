{
  "name": "@4lt7ab/animations",
  "version": "0.2.23",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "NODE_ENV=production bunup src/index.ts --format esm,cjs --dts --no-splitting --external @4lt7ab/core --external react --external react-dom && bun run ../../scripts/rewrite-core-imports.ts .",
    "typecheck": "tsc --noEmit"
  }
}
