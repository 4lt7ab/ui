{
  "name": "@4lt7ab/monorepo",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "bunup": "0.16.31",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "5.9.3",
    "vite": "8.0.8"
  },
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "bun run --filter '@4lt7ab/core' build && bun run --filter '@4lt7ab/ui' --filter '@4lt7ab/content' --filter '@4lt7ab/animations' build",
    "typecheck": "bun run --filter '*' typecheck",
    "prepublish": "bun run build"
  }
}
