{
  "name": "@4lt7ab/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./content": {
      "import": "./dist/content/index.js",
      "require": "./dist/content/index.cjs",
      "types": "./dist/content/index.d.ts"
    },
    "./themes/*.css": "./src/themes/*.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/themes/*.css"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bunup": "latest",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.8"
  },
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "bunup src/index.ts src/content/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "prepublish": "bun run build"
  }
}
