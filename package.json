{
  "name": "@4lt7ab/ui",
  "private": true,
  "version": "0.2.32",
  "type": "module",
  "exports": {
    "./core": {
      "types": "./packages/core/dist/index.d.ts",
      "import": "./packages/core/dist/index.js",
      "require": "./packages/core/dist/index.cjs"
    },
    "./ui": {
      "types": "./packages/ui/dist/index.d.ts",
      "import": "./packages/ui/dist/index.js",
      "require": "./packages/ui/dist/index.cjs"
    },
    "./content": {
      "types": "./packages/content/dist/index.d.ts",
      "import": "./packages/content/dist/index.js",
      "require": "./packages/content/dist/index.cjs"
    },
    "./animations": {
      "types": "./packages/animations/dist/index.d.ts",
      "import": "./packages/animations/dist/index.js",
      "require": "./packages/animations/dist/index.cjs"
    }
  },
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "bunup": "0.16.31",
    "esbuild": "^0.25.0",
    "jsdom": "^26.1.0",
    "typescript": "5.9.3",
    "vitest": "^3.1.1"
  },
  "scripts": {
    "prepare": "git config core.hooksPath scripts",
    "dev": "bun run --filter '@4lt7ab/demo' dev",
    "build": "bun run --filter '@4lt7ab/core' build && bun run --filter '@4lt7ab/ui' --filter '@4lt7ab/content' --filter '@4lt7ab/animations' build && bun run scripts/verify-exports.ts",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "typecheck": "bun run --filter '*' typecheck",
    "prepublish": "bun run build"
  }
}
