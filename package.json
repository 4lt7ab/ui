{
  "name": "@4lt7ab/monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bunup": "latest",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.8"
  },
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "bun run --filter '@4lt7ab/ui' build && bun run --filter '@4lt7ab/content' --filter '@4lt7ab/animations' build",
    "typecheck": "bun run --filter '*' typecheck",
    "prepublish": "bun run build"
  }
}
